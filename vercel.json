{
  "buildCommand": "node scripts/build.js",
  "outputDirectory": "dist",
  "functions": {
    "api/lead.js": {
      "includeFiles": "pages/**"
    },
    "api/pages.js": {
      "includeFiles": "pages/**"
    },
    "api/health.js": {
      "includeFiles": "pages/**"
    },
    "api/publish.js": {
      "includeFiles": "{pages/**,lib/testimonials.json,shared/public/logos/**}"
    },
    "api/logo.js": {
      "includeFiles": "pages/**"
    },
    "api/testimonial.js": {
      "includeFiles": "{pages/**,lib/testimonials.json}"
    }
  },
  "rewrites": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "office.coconutva.com"
        }
      ],
      "destination": "/trades-office-admin/"
    },
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "books.coconutva.com"
        }
      ],
      "destination": "/trades-bookkeeper/"
    }
  ],
  "redirects": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "get.coconutva.com"
        }
      ],
      "missing": [
        {
          "type": "query",
          "key": "ec_b2b"
        }
      ],
      "destination": "https://www.coconutva.com/",
      "permanent": false
    }
  ]
}
